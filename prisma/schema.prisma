// Prisma schema file for a sports-related application with user authentication and Google Calendar integration.
// Learn more about Prisma schema: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Model to store user account information, necessary for NextAuth.js integration
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Model to store user sessions
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Model representing a football club
model FootballClub {
  id               Int                  @id @default(autoincrement())
  clubName         String
  league           String
  matchDays        Matchday[]
}

// Model representing a user in the system
model User {
  id                String                    @id @default(cuid())
  name              String?
  email             String?                   @unique
  emailVerified     DateTime?
  accounts          Account[]
  sessions          Session[]
  favoriteClubs     UserFavoriteClub[]
  googleCalendars   GoogleCalendarIntegration[]
}

// Model to store verification tokens for email or other purposes
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Model representing a match day for a football club
model Matchday {
  id        Int          @id @default(autoincrement())
  matchDate DateTime
  opponent  String
  location  String
  clubId    Int
  club      FootballClub @relation(fields: [clubId], references: [id])
}

// Model for integrating with Google Calendar
model GoogleCalendarIntegration {
  id               Int      @id @default(autoincrement())
  userId           String
  calendarId       String
  syncFrequency    String
  lastSyncTimestamp DateTime
  user             User     @relation(fields: [userId], references: [id])
}

// Junction table for many-to-many relationship between User and FootballClub
model UserFavoriteClub {
  id     Int          @id @default(autoincrement())
  userId String
  clubId Int
  user   User         @relation(fields: [userId], references: [id])
}
